---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — EVIDENT</title>
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('evident-theme');
          var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved || (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body>
    <nav>
      <strong>EVIDENT</strong>
      <a href="/">Claims</a>
      <a href="/coverage">Coverage</a>
      <a href="/composer">Composer</a>
      <span class="spacer"></span>
      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
      >
        <span class="icon-moon">☾ Dark</span>
        <span class="icon-sun">☀ Light</span>
      </button>
    </nav>
    <main>
      <slot />
    </main>
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var cur = document.documentElement.dataset.theme;
          var next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem('evident-theme', next); } catch (e) {}
        });
        // Reflect OS changes only when the user has not chosen explicitly
        if (window.matchMedia) {
          var mq = window.matchMedia('(prefers-color-scheme: dark)');
          mq.addEventListener('change', function (ev) {
            var saved = null;
            try { saved = localStorage.getItem('evident-theme'); } catch (e) {}
            if (!saved) {
              document.documentElement.dataset.theme = ev.matches ? 'dark' : 'light';
            }
          });
        }
      })();
    </script>
  </body>
</html>
